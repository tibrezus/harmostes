# Dockerfile.ui — harmostes-ui: multi-tenant self-service web interface.
# Single-stage Go build. Templates + static assets are embedded via go:embed.

FROM golang:1.25-bookworm AS builder

WORKDIR /src

# Cache deps
COPY go.mod go.sum ./
RUN go mod download

# Build
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags "-X main.version=$(git describe --tags --always 2>/dev/null || echo dev)" \
    -o /out/harmostes-ui \
    ./cmd/harmostes-ui/

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /out/harmostes-ui /harmostes-ui

USER nonroot
ENTRYPOINT ["/harmostes-ui"]
